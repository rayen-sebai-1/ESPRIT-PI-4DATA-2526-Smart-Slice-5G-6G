# -----------------------------------------------------------------------
# Data – keep directory structure and READMEs; ignore all CSV files
# -----------------------------------------------------------------------

# Ignore any CSVs that still sit directly in data/
data/*.csv

# Ignore all CSVs inside data/raw/ (large binary-like files)
data/raw/*.csv

# Ignore generated processed outputs
data/processed/*.csv

# Track only the README files and the folder skeleton
!data/README.md
!data/raw/
!data/processed/

# -----------------------------------------------------------------------
# MLflow – tracking store (can be large; re-generated by training scripts)
# -----------------------------------------------------------------------
mlruns/

# -----------------------------------------------------------------------
# Python artefacts
# -----------------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
dist/
build/
.pytest_cache/

# -----------------------------------------------------------------------
# Notebooks – optional: keep outputs or strip them before committing
# -----------------------------------------------------------------------
.ipynb_checkpoints/

# -----------------------------------------------------------------------
# OS / editor
# -----------------------------------------------------------------------
.DS_Store
Thumbs.db
.vscode/
.idea/
