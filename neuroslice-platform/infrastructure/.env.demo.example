# NeuroSlice Scenario B — DEMO configuration
# This file documents env vars needed for a full demo run, including the
# offline MLOps pipeline. Copy to .env and set required secrets before use.
#
# IMPORTANT: Do not commit .env files with real secrets to version control.

# Required secrets:
DASHBOARD_JWT_SECRET=demo-jwt-secret-please-change-in-production
AUTH_DB_PASSWORD=demo-auth-db-pass
DASHBOARD_DB_PASSWORD=demo-dashboard-db-pass
INFLUXDB_TOKEN=neuroslice_token_12345

# MLOps pipeline ENABLED for demo (requires Docker socket access in mlops-runner):
MLOPS_PIPELINE_ENABLED=true
MLOPS_PIPELINE_TIMEOUT_SECONDS=7200
MLOPS_RUNNER_TOKEN=demo-runner-token-change-me

# Simulation speed (60x real time by default):
TICK_INTERVAL_SEC=2.0
SIM_SPEED=60.0

# Dashboard uses live BFF data (default):
DASHBOARD_DATA_PROVIDER=bff

# Ollama must be running on the host at port 11434:
OLLAMA_BASE_URL=http://host.docker.internal:11434
RCA_OLLAMA_MODEL=qwen2.5:3b-instruct
COPILOT_OLLAMA_MODEL=qwen2.5:3b-instruct
