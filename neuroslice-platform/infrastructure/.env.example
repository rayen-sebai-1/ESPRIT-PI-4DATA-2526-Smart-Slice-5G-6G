# NeuroSlice Scenario B — environment variable template
# Copy to .env and fill in required values before running docker compose.
#
# Required (no defaults):
DASHBOARD_JWT_SECRET=change-me-jwt-secret-min-32-chars
AUTH_DB_PASSWORD=change-me-auth-db-password
DASHBOARD_DB_PASSWORD=change-me-dashboard-db-password
INFLUXDB_TOKEN=neuroslice_token_12345

# Optional overrides (defaults shown):
# SITE_ID=TT-SFAX-02
# TICK_INTERVAL_SEC=2.0
# SIM_SPEED=60.0
# DASHBOARD_DATA_PROVIDER=bff

# Kong gateway — optional extra CORS origin for deployed frontends.
# Set to the full origin URL of your staging/production frontend, e.g.:
#   KONG_EXTRA_CORS_ORIGIN=https://dashboard.example.com
# Leave unset to allow only localhost (default).
# KONG_EXTRA_CORS_ORIGIN=

# Port overrides:
# REDIS_PORT=6379
# API_PORT=8000
# DASHBOARD_KONG_PORT=8008
# DASHBOARD_FRONTEND_PORT=5173
# GRAFANA_PORT=3000
# PROMETHEUS_PORT=9090
# FAULT_ENGINE_PORT=7004
# RCA_AGENT_PORT=7005
# COPILOT_AGENT_PORT=7006

# Grafana:
# GRAFANA_USER=admin
# GRAFANA_PASSWORD=neuroslice

# Ollama (agentic AI — requires local Ollama on host):
# OLLAMA_BASE_URL=http://host.docker.internal:11434
# RCA_OLLAMA_MODEL=qwen2.5:3b-instruct
# COPILOT_OLLAMA_MODEL=qwen2.5:3b-instruct

# MLOps pipeline — DISABLED by default (Docker socket access required).
# Enable only for Scenario B demo/testing.
MLOPS_PIPELINE_ENABLED=false
MLOPS_PIPELINE_TIMEOUT_SECONDS=7200
MLOPS_RUNNER_TOKEN=change-me-local-token
