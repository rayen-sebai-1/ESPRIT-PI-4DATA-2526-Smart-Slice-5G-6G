# neuroslice-platform infrastructure environment variables
# Copy this file to .env and adjust values as needed.

# Site identity
SITE_ID=TT-SFAX-02

# Simulation speed
# 1 real second = SIM_SPEED simulated seconds (default: 60 = 1 min/sec)
TICK_INTERVAL_SEC=2.0
SIM_SPEED=60.0

# Redis
REDIS_PORT=6379
STREAM_MAXLEN=10000

# AIOps runtime thresholds
CONGESTION_THRESHOLD=0.5
SLICE_MISMATCH_CONFIDENCE_THRESHOLD=0.8
SLA_RISK_THRESHOLD=0.5
MODEL_POLL_INTERVAL_SEC=60

# Public service ports
API_PORT=8000
VES_PORT=7001
NETCONF_PORT=7002
FAULT_ENGINE_PORT=7004
RCA_AGENT_PORT=7005
COPILOT_AGENT_PORT=7006
EXPORTER_PORT=9091
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
DASHBOARD_POSTGRES_PORT=5432
DASHBOARD_FRONTEND_PORT=5173
DASHBOARD_KONG_PORT=8008

# Agentic AI tier (RCA + Copilot)
OLLAMA_BASE_URL=http://host.docker.internal:11434
RCA_OLLAMA_MODEL=qwen2.5:3b-instruct
RCA_AGENT_MAX_RETRIES=3
RCA_ENABLE_HEURISTIC_FALLBACK=true
COPILOT_OLLAMA_MODEL=qwen2.5:3b-instruct
COPILOT_OLLAMA_TIMEOUT_SECONDS=60

# Optional Scenario B MLOps profile ports
MLOPS_POSTGRES_PORT=5433
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MLFLOW_TRACKING_PORT=5000
MLOPS_API_PORT=8010

# Scenario B MLOps profile settings
MLOPS_POSTGRES_DB=mlflow
MLOPS_POSTGRES_USER=mlflow
MLOPS_POSTGRES_PASSWORD=mlflow123
MLFLOW_ARTIFACT_BUCKET=mlflow-artifacts
MLFLOW_TRACKING_URI=http://mlflow-server:5000
MLFLOW_BACKEND_STORE_URI=postgresql+psycopg2://mlflow:mlflow123@mlops-postgres:5432/mlflow
MLFLOW_ARTIFACT_ROOT=s3://mlflow-artifacts
MLFLOW_S3_ENDPOINT_URL=http://minio:9000
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin123
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MLOPS_LOG_MONITORING_MODE=logstash

# Grafana credentials
GRAFANA_USER=admin
GRAFANA_PASSWORD=neuroslice

# Dashboard tier
# Local Docker Compose can use placeholder values.
# Production must replace every password or secret below with securely generated values.
DASHBOARD_POSTGRES_DB=neuroslice_dashboard
DASHBOARD_POSTGRES_SUPERUSER=neuroslice
DASHBOARD_POSTGRES_SUPERPASS=change-me-superuser-password
AUTH_DB_USER=auth_app
AUTH_DB_PASSWORD=change-me-auth-user-password
DASHBOARD_DB_USER=dashboard_app
DASHBOARD_DB_PASSWORD=change-me-dashboard-user-password
DASHBOARD_JWT_SECRET=replace-with-a-long-random-jwt-secret
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRES_DAYS=7
ARGON2_MEMORY_COST=65536
ARGON2_TIME_COST=3
ARGON2_PARALLELISM=4
REFRESH_COOKIE_NAME=neuroslice_refresh_token
# Keep the refresh cookie scoped to Kong auth routes.
REFRESH_COOKIE_PATH=/api/auth
# Local HTTP development: false. Production behind HTTPS: true.
REFRESH_COOKIE_SECURE=false
# Keep this at lax or strict in production.
REFRESH_COOKIE_SAMESITE=lax
DASHBOARD_DATA_PROVIDER=temporary_mock

# Optional automatic admin bootstrap for auth-service.
# Leave INITIAL_ADMIN_EMAIL and INITIAL_ADMIN_PASSWORD empty to skip auto-seeding.
INITIAL_ADMIN_FULL_NAME=NeuroSlice Administrator
INITIAL_ADMIN_EMAIL=
INITIAL_ADMIN_PASSWORD=
INITIAL_ADMIN_ROLE=ADMIN
