# neuroslice-sim environment variables
# Copy this file to .env and adjust values

# Site identity
SITE_ID=TT-SFAX-02

# Simulation speed
# 1 real second = SIM_SPEED simulated seconds (default: 60 = 1 min/sec)
TICK_INTERVAL_SEC=2.0
SIM_SPEED=60.0

# Redis
REDIS_PORT=6379
STREAM_MAXLEN=10000

# AIOps runtime thresholds (Scenario B)
CONGESTION_THRESHOLD=0.5
SLICE_MISMATCH_CONFIDENCE_THRESHOLD=0.8
SLA_RISK_THRESHOLD=0.5

# Service ports
API_PORT=8000
VES_PORT=7001
NETCONF_PORT=7002
FAULT_ENGINE_PORT=7004
EXPORTER_PORT=9091
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

# Grafana credentials
GRAFANA_USER=admin
GRAFANA_PASSWORD=neuroslice

# Dashboard tier (neuroslice-tunisia)
DASHBOARD_FRONTEND_PORT=5173
DASHBOARD_KONG_PORT=8008
DASHBOARD_JWT_SECRET=neuroslice-draft-secret


DASHBOARD_POSTGRES_SUPERPASS=StrongSecurePass_123!
AUTH_DB_PASSWORD=AuthStrongPass_123!
DASHBOARD_DB_PASSWORD=DashboardStrongPass_123!