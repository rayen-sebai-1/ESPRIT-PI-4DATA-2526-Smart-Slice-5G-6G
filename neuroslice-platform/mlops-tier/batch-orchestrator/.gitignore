# -----------------------------------------------------------------------
# Data – keep directory structure and READMEs; ignore all CSV files
# -----------------------------------------------------------------------


# Ignore generated processed outputs
data/processed/*.csv
data/processed/*.npz
data/processed/*.pkl

# Track only the README files and the folder skeleton
!data/README.md
!data/processed/

# -----------------------------------------------------------------------
# MLflow – tracking store (can be large; re-generated by training scripts)
# -----------------------------------------------------------------------
mlruns/
mlflow.db

# -----------------------------------------------------------------------
# Generated artifacts / model binaries
# -----------------------------------------------------------------------
artifacts/
models/*.pt
models/*.pth
models/*.pkl
models/*.joblib

# -----------------------------------------------------------------------
# Python artefacts
# -----------------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
dist/
build/
.pytest_cache/
.venv/

# -----------------------------------------------------------------------
# Notebooks – optional: keep outputs or strip them before committing
# -----------------------------------------------------------------------
.ipynb_checkpoints/

# -----------------------------------------------------------------------
# OS / editor
# -----------------------------------------------------------------------
.DS_Store
Thumbs.db
.vscode/
.idea/
