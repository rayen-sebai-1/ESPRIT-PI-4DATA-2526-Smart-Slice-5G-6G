name: smart-slice-5g-6g
conda_env: conda.yaml

entry_points:
  train_sla_5g:
    parameters:
      n_estimators: {type: int, default: 200}
      learning_rate: {type: float, default: 0.05}
    command: "python src/models/train_sla_5g.py --n_estimators {n_estimators} --learning_rate {learning_rate}"

  train_congestion_5g:
    command: "python src/models/train_congestion_5g.py"

  train_congestion_6g:
    parameters:
      seq_length: {type: int, default: 24}
      lstm_units: {type: int, default: 128}
      epochs: {type: int, default: 50}
      learning_rate: {type: float, default: 0.001}
    command: "python src/models/train_congestion_6g.py"

  train_slice_type_5g:
    parameters:
      n_estimators: {type: int, default: 20}
      learning_rate: {type: float, default: 0.05}
      max_depth: {type: int, default: 3}
      colsample_bytree: {type: float, default: 0.33}
      reg_lambda: {type: float, default: 15.0}
    command: "python src/models/train_slice_type_5g.py --n_estimators {n_estimators} --learning_rate {learning_rate} --max_depth {max_depth} --colsample_bytree {colsample_bytree} --reg_lambda {reg_lambda}"

  train_slice_type_6g:
    command: "python src/models/train_slice_type_6g.py"

  train_sla_6g:
    parameters:
      n_estimators: {type: int, default: 300}
      learning_rate: {type: float, default: 0.05}
      max_depth: {type: int, default: 6}
      subsample: {type: float, default: 0.8}
      colsample_bytree: {type: float, default: 0.8}
    command: "python src/models/train_sla_6g.py --n_estimators {n_estimators} --learning_rate {learning_rate} --max_depth {max_depth} --subsample {subsample} --colsample_bytree {colsample_bytree}"
